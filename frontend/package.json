{
  "name": "gix",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "tsc && vite build --minify false --mode development",
    "build": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write src",
    "check:lines": "node scripts/check-lines.mjs"
  },
  "dependencies": {
    "@wailsio/runtime": "latest",
    "d3-force": "^3.0.0",
    "motion": "^12.41.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.5",
    "vitest": "^3.2.0"
  }
}
